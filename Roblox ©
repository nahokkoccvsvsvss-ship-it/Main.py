-- سحب القائمة
local dragging, dragStart, dragOffset = false, nil, nil

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DeviceCheck"
screenGui.Parent = player:WaitForChild("PlayerGui")

local main = Instance.new("Frame")
main.Size = UDim2.new(0, 340, 0, 430)
main.Position = UDim2.new(0.5, -170, 0.5, -215)
main.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
main.BorderSizePixel = 0
main.Active = true
main.Parent = screenGui
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 14)

-- سحب
local dragBar = Instance.new("Frame")
dragBar.Size = UDim2.new(1, 0, 0, 48)
dragBar.BackgroundTransparency = 1
dragBar.Parent = main

dragBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        dragOffset = main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - dragStart
        main.Position = UDim2.new(dragOffset.X.Scale, dragOffset.X.Offset + d.X, dragOffset.Y.Scale, dragOffset.Y.Offset + d.Y)
    end
end)

