-- أنيميشن الفحص
task.spawn(function()
    local pct = 0
    while pct < 100 and barFill and barFill.Parent do
        pct = pct + math.random(1, 3)
        if pct > 100 then pct = 100 end
        
        TweenService:Create(barFill, TweenInfo.new(0.15), {
            Size = UDim2.new(pct/100, 0, 1, 0)
        }):Play()
        
        barText.Text = "جاري فحص الجهاز... " .. pct .. "%"
        
        if pct > 80 then
            barFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            barText.TextColor3 = Color3.fromRGB(255, 70, 70)
        elseif pct > 50 then
            barFill.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        end
        
        if pct >= 100 then
            barText.Text = "⚠️ خطر! بند نهائي"
            icon.Text = "💀"
        end
        
        task.wait(0.08)
    end
end)
